<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.recruit.mapper.AdPositionMapper">

    <resultMap id="BaseResultMap" type="com.recruit.entity.AdPosition">
        <id column="id" property="id"/>
        <result column="position_key" property="positionKey"/>
        <result column="position_name" property="positionName"/>
        <result column="width" property="width"/>
        <result column="height" property="height"/>
        <result column="status" property="status"/>
    </resultMap>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM ad_position
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM ad_position WHERE id = #{id}
    </select>

</mapper>
